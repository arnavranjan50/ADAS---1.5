from ultralytics import YOLO

def main():
    model = YOLO(r"Paste your best.pt from weights path after executing training module code")

    model.train(
        data=r"Paste your data.yaml path",
        epochs=50,
        imgsz=640,
        batch=16,
        device=0,
        workers=0   # extra safety for Windows
    )

if __name__ == "__main__":
    main()
